# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-64-char-string

# ── Groq LLM (primary) ────────────────────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=350

# ── RAG ───────────────────────────────────────────────────────────────────────
RAG_ENABLED=true
RAG_TOP_K=3
RAG_FORCE_REBUILD=false

# ── App ───────────────────────────────────────────────────────────────────────
FLASK_ENV=production
FLASK_DEBUG=false
PORT=5000
